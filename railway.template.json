{
  "name": "QuantumOS",
  "description": "QuantumOS API with PostgreSQL — no manual DATABASE_URL wiring required",
  "services": {
    "QOS": {
      "source": {
        "repo": "sid776/QOS",
        "branch": "main"
      },
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile"
      },
      "variables": {
        "QUANTUMOS_ENV": "production",
        "DEFAULT_TENANT_ID": "tenant_demo"
      }
    }
  }
}
