DATABASE_URL=postgresql://quantumos:quantumos@localhost:5432/quantumos
API_HOST=0.0.0.0
API_PORT=8000
DEFAULT_TENANT_ID=tenant_demo
QUANTUMOS_ENV=development
VITE_API_URL=http://localhost:8000

# --- Quantum providers (optional) ---

# IBM Quantum (free tier): https://quantum.ibm.com/
# IBM_QUANTUM_TOKEN=your_token
# IBM_QUANTUM_BACKEND=ibm_torino

# Microsoft Azure Quantum: https://portal.azure.com/
# AZURE_QUANTUM_RESOURCE_ID=/subscriptions/.../resourceGroups/.../providers/Microsoft.Quantum/Workspaces/...
# Or:
# AZURE_QUANTUM_SUBSCRIPTION_ID=
# AZURE_QUANTUM_RESOURCE_GROUP=
# AZURE_QUANTUM_WORKSPACE=
# AZURE_QUANTUM_TARGET=rigetti.sim.qvm

# Origin Quantum (China) — free local CPUQVM via pyqpanda3; cloud via research program
# https://qcloud.originqc.com.cn/en/researchincentive
# ORIGIN_QUANTUM_API_KEY=your_api_key
# ORIGIN_QUANTUM_DEVICE=WK_C180
# ORIGIN_QUANTUM_PREFER_CLOUD=false

# Allow cloud backends in job constraints (dashboard sets per-job)
# QUANTUMOS_ALLOW_CLOUD_DEFAULT=false

# --- Optional local frameworks (see README "Quantum software stack") ---

# TensorFlow Quantum — Python < 3.12 only today; provider registers but reports unavailable on 3.12+
# pip install -e ".[tfq]"

# NVIDIA cuQuantum GPU sim — requires CUDA + cuQuantum drivers
# pip install -e ".[quantum,cuquantum]"
